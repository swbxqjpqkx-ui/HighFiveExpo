{
  "expo": {
    "name": "High Five",
    "slug": "highfive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2FAF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.highfive.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "High Five uses your location to show it on the dashboard."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2FAF5"
      },
      "package": "com.highfive.app",
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "High Five uses your location to show it on the dashboard."
        }
      ]
    ]
  }
}
